<Window x:Class="PR_17_KosmeticheskayaLaja.Pages.OrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PR_17_KosmeticheskayaLaja.Pages"
        mc:Ignorable="d"
Title="Оформление заказа" Height="300" Width="400" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Выберите дату получения (доступно на ближайшие 7 дней):" Margin="0,0,0,5"/>
            <DatePicker x:Name="DPickerDelivery" Margin="0,0,0,15"/>

            <TextBlock Text="Способ оплаты:" Margin="0,0,0,5"/>
            <ComboBox x:Name="ComboPayment" Margin="0,0,0,20">
                <ComboBoxItem Content="Карта"/>
                <ComboBoxItem Content="Наличные"/>
                <ComboBoxItem Content="QR-код"/>
            </ComboBox>

            <UniformGrid Columns="2">
                <Button Content="Отмена" Height="30" Margin="5" Click="BtnCancel_Click"/>
                <Button Content="Подтвердить заказ" Height="30" Margin="5" Background="LightGreen" Click="BtnConfirm_Click"/>
            </UniformGrid>
        </StackPanel>
    </Grid>
</Window>
