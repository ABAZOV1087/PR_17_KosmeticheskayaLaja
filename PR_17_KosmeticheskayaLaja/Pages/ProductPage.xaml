<Page x:Class="PR_17_KosmeticheskayaLaja.Pages.ProductPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PR_17_KosmeticheskayaLaja.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
Title="Каталог косметики" Background="#F9F9F9">

    <Border Padding="15">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Button Content="← Назад к записи" Width="120" Height="25" HorizontalAlignment="Left" Click="BtnBack_Click"/>
                <TextBlock Text="Каталог продукции" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
            </Grid>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
                <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="TBoxSearch" Width="180" Height="25" VerticalContentAlignment="Center" TextChanged="TBoxSearch_TextChanged"/>

                <TextBlock Text="Производитель:" VerticalAlignment="Center" Margin="15,0,5,0"/>
                <ComboBox x:Name="ComboFilter" Width="150" Height="25" DisplayMemberPath="Name" SelectionChanged="ComboFilter_SelectionChanged"/>

                <TextBlock Text="Цена:" VerticalAlignment="Center" Margin="15,0,5,0"/>
                <ComboBox x:Name="ComboSort" Width="130" Height="25" SelectionChanged="ComboSort_SelectionChanged">
                    <ComboBoxItem Content="Без сортировки"/>
                    <ComboBoxItem Content="По возрастанию"/>
                    <ComboBoxItem Content="По убыванию"/>
                </ComboBox>
            </StackPanel>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <ListBox x:Name="LBoxProducts" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel HorizontalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" Width="220" Height="260" Margin="10" CornerRadius="6" BorderBrush="#E0E0E0" BorderThickness="1" Padding="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Background="#F2F2F2" CornerRadius="4" Margin="0,0,0,10">
                                        <TextBlock Text="🛍️" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <TextBlock Grid.Row="1" Text="{Binding Title}" FontSize="14" FontWeight="Bold" TextWrapping="Wrap" Height="40"/>

                                    <TextBlock Grid.Row="2" Text="{Binding Manufacturers.Name}" Foreground="Gray" FontSize="12" Margin="0,2,0,8"/>

                                    <DockPanel Grid.Row="3">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Price, StringFormat={}{0} ₽}" FontSize="14" FontWeight="Black" Foreground="#4A90E2"/>
                                            <TextBlock Text="{Binding Discount, StringFormat={}Скидка: {0}%}" FontSize="11" Foreground="Green"/>
                                        </StackPanel>
                                        <Button Content="В корзину" Width="80" Height="28" HorizontalAlignment="Right" Background="#4A90E2" Foreground="White" BorderBrush="{x:Null}" Click="BtnAddToCart_Click"/>
                                    </DockPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>
        </Grid>
    </Border>
</Page>
