<Page x:Class="PR_17_KosmeticheskayaLaja.Pages.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PR_17_KosmeticheskayaLaja.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Панель Администратора" Background="White">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Администрирование пользователей" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock Text=" | Режим: Полный доступ" Foreground="Gray" FontSize="14" VerticalAlignment="Center" Margin="5,0,0,0"/>
            </StackPanel>
            <Button Content="Выйти из системы" Width="130" Height="25" HorizontalAlignment="Right" Click="BtnLogout_Click"/>
        </Grid>

        <DataGrid x:Name="DGridUsers" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ID_User}" Width="50"/>
                <DataGridTextColumn Header="ФИО Пользователя" Binding="{Binding FullName}" Width="*"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
                <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="100"/>
                <DataGridTextColumn Header="Роль в системе" Binding="{Binding Roles.RoleName}" Width="120"/>
                <DataGridTextColumn Header="Статус аккаунта" Binding="{Binding IsFrozen, Converter={StaticResource BooleanToFreezeConverter}}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <TextBlock Text="Изменить роль выбранного:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="13"/>
            <ComboBox x:Name="ComboRoles" Width="130" Height="30" DisplayMemberPath="RoleName" Margin="0,0,15,0"/>
            <Button Content="Применить роль" Width="120" Height="30" Margin="0,0,20,0" Click="BtnChangeRole_Click"/>

            <Button Content="Заблокировать / Разморозить" Width="190" Height="30" Background="LightSkyBlue" FontWeight="Bold" Click="BtnToggleFreeze_Click"/>
        </StackPanel>
    </Grid>
</Page>