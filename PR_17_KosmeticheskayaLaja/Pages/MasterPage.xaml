<Page x:Class="PR_17_KosmeticheskayaLaja.Pages.MasterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PR_17_KosmeticheskayaLaja.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Панель Мастера" Background="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Расписание на дату:" VerticalAlignment="Center" FontSize="14" Margin="0,0,10,0"/>
            <DatePicker x:Name="DPickerSchedule" Width="150" SelectedDateChanged="DPickerSchedule_SelectedDateChanged"/>
            <Button Content="Сегодня" Width="80" Margin="10,0,0,0" Click="BtnToday_Click"/>
            <TextBlock x:Name="TxtMasterInfo" Text="Мастер: " FontSize="14" FontWeight="Bold" Margin="30,0,0,0" VerticalAlignment="Center" Foreground="DarkSlateGray"/>
        </StackPanel>

        <DataGrid x:Name="DGridAppointments" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Время" Binding="{Binding AppointmentTime}" Width="80"/>
                <DataGridTextColumn Header="Клиент" Binding="{Binding Users1.FullName}" Width="*"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Users1.Phone}" Width="120"/>
                <DataGridTextColumn Header="Услуга" Binding="{Binding MasterServices.ServiceTypes.Title}" Width="150"/>
                <DataGridTextColumn Header="Комментарий" Binding="{Binding Comment}" Width="180"/>
                <DataGridTextColumn Header="Оплата" Binding="{Binding PaymentMethod}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Удалить запись" Width="120" Height="35" Background="LightCoral" Margin="0,0,10,0" Click="BtnDeleteAppointment_Click"/>
            <Button Content="Выйти из аккаунта" Width="150" Height="35" Click="BtnLogout_Click"/>
        </StackPanel>
    </Grid>
</Page>
