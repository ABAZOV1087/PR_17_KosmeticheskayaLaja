<Page x:Class="PR_17_KosmeticheskayaLaja.Pages.MasterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PR_17_KosmeticheskayaLaja.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
Title="Панель Мастера" Background="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <TextBlock x:Name="TBlockWelcome" Text="Расписание мастера" FontSize="20" FontWeight="Bold"/>
            <Button Content="Выйти" Width="80" Height="25" HorizontalAlignment="Right" Click="BtnLogout_Click"/>
        </Grid>

        <DataGrid x:Name="DGridAppointments" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal" Background="Transparent">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Дата" Binding="{Binding AppointmentDate, StringFormat={}{0:dd.MM.yyyy}}" Width="100"/>
                <DataGridTextColumn Header="Время" Binding="{Binding AppointmentTime}" Width="80"/>
                <DataGridTextColumn Header="Услуга" Binding="{Binding ServiceTypes.Title}" Width="200"/>
                <DataGridTextColumn Header="Клиент" Binding="{Binding Users1.FullName}" Width="200"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Comment}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Отменить выбранный сеанс" Width="200" Height="35" Background="#E74C3C" Foreground="White" FontWeight="Bold" BorderBrush="{x:Null}" Click="BtnCancelAppointment_Click"/>
        </StackPanel>
    </Grid>
</Page>
