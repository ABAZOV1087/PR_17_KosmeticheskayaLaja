<Page x:Class="PR_17_KosmeticheskayaLaja.Pages.AppointmentConfirmPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PR_17_KosmeticheskayaLaja.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
Title="Подтверждение записи" Background="White">
    <Grid Margin="30">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="400">
            <TextBlock Text="Подтверждение записи на сеанс" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

            <TextBlock x:Name="TxtService" Text="Тип услуги: " FontSize="14" Margin="0,0,0,5"/>
            <TextBlock x:Name="TxtMaster" Text="Мастер: " FontSize="14" Margin="0,0,0,5"/>
            <TextBlock x:Name="TxtDateTime" Text="Дата и время: " FontSize="14" Margin="0,0,0,15"/>

            <TextBlock Text="Способ оплаты:" Margin="0,0,0,5"/>
            <ComboBox x:Name="ComboPayment" Margin="0,0,0,15">
                <ComboBoxItem Content="Карта"/>
                <ComboBoxItem Content="Наличные после услуги"/>
            </ComboBox>

            <TextBlock Text="Комментарий к записи (необязательно):" Margin="0,0,0,5"/>
            <TextBox x:Name="TBoxComment" Height="60" TextWrapping="Wrap" Margin="0,0,0,25"/>

            <UniformGrid Columns="2">
                <Button Content="Назад" Height="35" Margin="5" Click="BtnBack_Click"/>
                <Button Content="Записаться" Height="35" Margin="5" Background="LightGreen" Click="BtnSave_Click"/>
            </UniformGrid>
        </StackPanel>
    </Grid>
</Page>
