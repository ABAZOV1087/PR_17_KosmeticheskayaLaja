<Page x:Class="PR_17_KosmeticheskayaLaja.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PR_17_KosmeticheskayaLaja.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Авторизация" Background="#F4F4F4">
    <Grid>
        <Border Background="White" Width="350" Height="300" CornerRadius="8" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect Color="Gray" BlurRadius="15" Direction="270" ShadowDepth="3" Opacity="0.2"/>
            </Border.Effect>

            <StackPanel Margin="30,20,30,20">
                <TextBlock Text="Авторизация" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20" Foreground="#333333"/>

                <TextBlock Text="Логин:" Margin="0,0,0,5" Foreground="Gray"/>
                <TextBox x:Name="TBoxLogin" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,15" Padding="5,0,0,0"/>

                <TextBlock Text="Пароль:" Margin="0,0,0,5" Foreground="Gray"/>
                <PasswordBox x:Name="PBoxPassword" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,20" Padding="5,0,0,0"/>

                <Button Content="Войти" Height="35" Background="#4A90E2" Foreground="White" FontWeight="Bold" BorderBrush="{x:Null}" Click="BtnLogin_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
