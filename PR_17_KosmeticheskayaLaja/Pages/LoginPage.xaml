<Page x:Class="PR_17_KosmeticheskayaLaja.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PR_17_KosmeticheskayaLaja.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LoginPage">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="200">
            <TextBlock Text="Логин"/>
            <TextBox Name="TBoxLogin" Margin="0,0,0,10"/>

            <TextBlock Text="Пароль"/>
            <PasswordBox Name="PBoxPassword" Margin="0,0,0,20"/>

            <Button Content="Войти" Click="BtnLogin_Click" Height="30"/>
        </StackPanel>
    </Grid>
</Page>
