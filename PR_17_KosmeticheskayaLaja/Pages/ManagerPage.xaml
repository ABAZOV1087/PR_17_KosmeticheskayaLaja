<Page x:Class="PR_17_KosmeticheskayaLaja.Pages.ManagerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PR_17_KosmeticheskayaLaja.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
     Title="Панель Менеджера" Background="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Управление заказами товаров" FontSize="20" FontWeight="Bold"/>
            <Button Content="Выйти" Width="80" Height="25" HorizontalAlignment="Right" Click="BtnLogout_Click"/>
        </Grid>

        <DataGrid x:Name="DGridOrders" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal" Background="Transparent">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№ Заказа" Binding="{Binding ID_Order}" Width="80"/>
                <DataGridTextColumn Header="Клиент" Binding="{Binding Users.FullName}" Width="200"/>
                <DataGridTextColumn Header="Дата заказа" Binding="{Binding OrderDate, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="140"/>
                <DataGridTextColumn Header="Дата доставки" Binding="{Binding DeliveryDate, StringFormat={}{0:dd.MM.yyyy}}" Width="120"/>
                <DataGridTextColumn Header="Способ оплаты" Binding="{Binding PaymentMethod}" Width="130"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding PaymentMethod}" x:Name="ColStatus" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Выдать заказ (Закрыть)" Width="180" Height="35" Background="#2ECC71" Foreground="White" FontWeight="Bold" BorderBrush="{x:Null}" Click="BtnCloseOrder_Click"/>
        </StackPanel>
    </Grid>
</Page>