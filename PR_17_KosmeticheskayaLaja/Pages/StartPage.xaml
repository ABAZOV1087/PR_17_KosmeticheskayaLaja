<Page x:Class="PR_17_KosmeticheskayaLaja.Pages.StartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PR_17_KosmeticheskayaLaja.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Косметическая лажа - Главная">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
            <ComboBox x:Name="ComboMaster" Width="150" Margin="5" DisplayMemberPath="FullName"/>
            <ComboBox x:Name="ComboServiceType" Width="150" Margin="5" DisplayMemberPath="Title"/>
            <Button x:Name="BtnLogin" Content="Войти" Margin="5" Click="BtnLogin_Click"/>
            <Button x:Name="BtnAccount" Content="Аккаунт" Margin="5" Visibility="Collapsed"/>
            <Button Content="Товары" Margin="5" Click="BtnProducts_Click"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ListBox x:Name="ListServices" DisplayMemberPath="Title" SelectionChanged="ListServices_SelectionChanged" Margin="5"/>
            <ListBox x:Name="ListMasters" Grid.Column="1" DisplayMemberPath="FullName" SelectionChanged="ListMasters_SelectionChanged" Margin="5"/>
            <ListBox x:Name="ListAvailableTimes" Grid.Column="2" DisplayMemberPath="AppointmentTime" Margin="5"/>
        </Grid>
    </Grid>
</Page>
