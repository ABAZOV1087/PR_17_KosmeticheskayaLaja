<Page x:Class="PR_17_KosmeticheskayaLaja.Pages.CartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PR_17_KosmeticheskayaLaja.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
Title="Корзина" Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListBox x:Name="LBoxCart" Grid.Row="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" HorizontalContentAlignment="Center">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel HorizontalAlignment="Center" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Margin="10" Width="220" Height="150" Background="White">
                        <StackPanel Margin="10" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" TextWrapping="Wrap" Height="40"/>
                            <TextBlock Text="{Binding Price, StringFormat={}{0} руб.}" FontSize="16" Foreground="Green"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                <Button Content="-" Width="30" Click="BtnDecrease_Click" Tag="{Binding ID_Product}"/>
                                <TextBlock Text="{Binding QuantityInCart}" Width="40" TextAlignment="Center" FontSize="14" VerticalAlignment="Center"/>
                                <Button Content="+" Width="30" Click="BtnIncrease_Click" Tag="{Binding ID_Product}"/>
                                <Button Content="Удалить" Margin="10,0,0,0" Background="LightCoral" Click="BtnDelete_Click" Tag="{Binding ID_Product}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20">
            <TextBlock x:Name="TextTotal" Text="Итого: 0 руб." FontSize="18" VerticalAlignment="Center" Margin="0,0,20,0"/>
            <Button Content="Назад" Width="100" Height="35" Margin="0,0,10,0" Click="BtnBack_Click"/>
            <Button Content="Оформить заказ" Width="150" Height="35" Background="LightGreen" Click="BtnOrder_Click"/>
        </StackPanel>
    </Grid>
</Page>
